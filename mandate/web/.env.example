# Mandate web — environment template. Copy to `.env.local` and fill in.
# Leaving the contract addresses blank keeps the app in DEMO MODE (synthetic
# live-looking events), so every page is fully demoable before deployment.

# Robinhood Chain testnet RPC (chainId 46630).
NEXT_PUBLIC_RH_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Deployed MandateVaultFactory address (from forge script output).
NEXT_PUBLIC_FACTORY_ADDRESS=

# A specific MandateVault address to watch in the Control Room / Ledger.
# If unset, the app stays in DEMO MODE.
NEXT_PUBLIC_VAULT_ADDRESS=

# Optional: Alchemy key for the sponsored RPC endpoint
# (https://robinhood-testnet.g.alchemy.com/v2/<KEY>). Falls back to the public RPC.
NEXT_PUBLIC_ALCHEMY_API_KEY=
